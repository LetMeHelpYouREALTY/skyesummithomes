{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm ci",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "skyesummithomes.com"
        }
      ],
      "destination": "https://www.skyesummithomes.com/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "query",
          "key": "s"
        }
      ],
      "destination": "https://www.skyesummithomes.com/search",
      "permanent": true
    },
    {
      "source": "/search",
      "has": [
        {
          "type": "query",
          "key": "s"
        }
      ],
      "destination": "https://www.skyesummithomes.com/search",
      "permanent": true
    },
    {
      "source": "/las-vegas-zip-code-map/",
      "destination": "https://www.skyesummithomes.com/las-vegas-zip-code-map",
      "permanent": true
    },
    {
      "source": "/invest/",
      "destination": "https://www.skyesummithomes.com/invest",
      "permanent": true
    },
    {
      "source": "/:path+/",
      "destination": "https://www.skyesummithomes.com/:path+",
      "permanent": true
    },
    {
      "source": "/:path((?!google)[^/]+).html",
      "destination": "https://www.skyesummithomes.com/:path",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "skyesummithomes.com"
        }
      ],
      "destination": "https://www.skyesummithomes.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-host",
          "value": "skyesummithomes.com"
        }
      ],
      "destination": "https://www.skyesummithomes.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.skyesummithomes.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/community",
      "destination": "/community/index.html"
    },
    {
      "source": "/sell",
      "destination": "/sell/index.html"
    },
    {
      "source": "/buy",
      "destination": "/buy/index.html"
    },
    {
      "source": "/valuation",
      "destination": "/valuation/index.html"
    },
    {
      "source": "/invest",
      "destination": "/invest/index.html"
    },
    {
      "source": "/relocate",
      "destination": "/relocate/index.html"
    },
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/mls-disclaimer",
      "destination": "/mls-disclaimer/index.html"
    },
    {
      "source": "/homes-for-sale-skye-summit",
      "destination": "/homes-for-sale-skye-summit/index.html"
    },
    {
      "source": "/404",
      "destination": "/404/index.html"
    },
    {
      "source": "/search",
      "destination": "/search/index.html"
    },
    {
      "source": "/las-vegas-zip-code-map",
      "destination": "/las-vegas-zip-code-map/index.html"
    },
    {
      "source": "/skye-summit-realtor",
      "destination": "/skye-summit-realtor/index.html"
    },
    {
      "source": "/skye-summit-faq",
      "destination": "/skye-summit-faq/index.html"
    },
    {
      "source": "/skye-summit-schools",
      "destination": "/skye-summit-schools/index.html"
    },
    {
      "source": "/living-in-skye-summit",
      "destination": "/living-in-skye-summit/index.html"
    },
    {
      "source": "/new-construction-skye-summit",
      "destination": "/new-construction-skye-summit/index.html"
    },
    {
      "source": "/skye-summit-hoa",
      "destination": "/skye-summit-hoa/index.html"
    },
    {
      "source": "/centennial-hills-real-estate",
      "destination": "/centennial-hills-real-estate/index.html"
    },
    {
      "source": "/skye-summit-home-prices",
      "destination": "/skye-summit-home-prices/index.html"
    },
    {
      "source": "/skye-summit-first-time-buyer",
      "destination": "/skye-summit-first-time-buyer/index.html"
    },
    {
      "source": "/skye-summit-vs-summerlin",
      "destination": "/skye-summit-vs-summerlin/index.html"
    },
    {
      "source": "/northwest-las-vegas-real-estate",
      "destination": "/northwest-las-vegas-real-estate/index.html"
    },
    {
      "source": "/office-location",
      "destination": "/office-location/index.html"
    },
    {
      "source": "/skye-summit-master-plan",
      "destination": "/skye-summit-master-plan/index.html"
    },
    {
      "source": "/skye-summit-interest-list",
      "destination": "/skye-summit-interest-list/index.html"
    },
    {
      "source": "/kb-home-vertice-skye-summit",
      "destination": "/kb-home-vertice-skye-summit/index.html"
    },
    {
      "source": "/olympia-companies-skye-summit",
      "destination": "/olympia-companies-skye-summit/index.html"
    },
    {
      "source": "/skye-summit-timeline",
      "destination": "/skye-summit-timeline/index.html"
    },
    {
      "source": "/woodside-homes-skye-summit",
      "destination": "/woodside-homes-skye-summit/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/script.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ]
}
