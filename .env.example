# --- Vercel (Project → Settings → Environment Variables) ---
# Required for contact + valuation forms → Follow Up Boss:
FUB_API_KEY=
#
# Google Cloud → Other products → Maps Platform → enable "Maps JavaScript API".
# Restrict key by HTTP referrer (Website restrictions):
#   https://www.skyesummithomes.com/*
#   https://skyesummithomes.com/*
#   http://localhost:*
# Vercel: set GOOGLE_MAPS_API_KEY; build must run `npm run build` (see vercel.json) so
# scripts/inject-google-maps-key.js embeds the key into las-vegas-zip-code-map/index.html.
GOOGLE_MAPS_API_KEY=
#
# Google Search Console HTML tag verification (optional; build injects default token)
GOOGLE_SITE_VERIFICATION=
#
# Parallel Search + Task API (optional; refresh SEO/GEO/AEO research)
PARALLEL_API_KEY=
#
# Local map test (PowerShell): $env:FORCE_MAPS_INJECT="1"; $env:GOOGLE_MAPS_API_KEY="your_key"; npm run build
# Then restore empty content= on las-vegas-zip-code-map meta before commit if the file changed.
